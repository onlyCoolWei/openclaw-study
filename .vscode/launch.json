{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug OpenClaw CLI",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": ["src/entry.ts", "agent", "--help"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "OPENCLAW_NO_RESPAWN": "1"
      }
    }
  ]
}
